#!/usr/bin/env sh
set -eu

if command -v python >/dev/null 2>&1; then
  python scripts/ci/preflight/pre_push_quality_gate.py
  exit $?
fi

if command -v py >/dev/null 2>&1; then
  py -3 scripts/ci/preflight/pre_push_quality_gate.py
  exit $?
fi

echo "pre-push quality gate: Python is required (python or py command not found)." >&2
exit 1
